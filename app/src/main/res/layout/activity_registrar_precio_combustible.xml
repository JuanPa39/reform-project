<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrar / Cambiar precio combustible"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Selector tipo combustible -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo de combustible"/>

    <Spinner
        android:id="@+id/spinnerCombustible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Selector estación -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccionar estación"
        android:layout_marginTop="15dp"/>

    <Spinner
        android:id="@+id/spinnerEstaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Precio -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo precio"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/editPrecio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingrese precio"
        android:inputType="numberDecimal"/>

    <Button
        android:id="@+id/buttonGuardarPrecio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar precio"
        android:layout_marginTop="20dp"/>

</LinearLayout>